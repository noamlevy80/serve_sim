{
  "name": "tiny-dense",
  "note": "Synthetic small dense transformer for end-to-end tests (a few MB of weights).",
  "global": {
    "num_layers": 4,
    "hidden_size": 256,
    "vocab_size": 2048,
    "tie_word_embeddings": true,
    "param_dtype_bytes": 2,
    "kv_dtype_bytes": 2,
    "layer_pattern": ["dense", "dense", "dense", "dense"]
  },
  "blocks": {
    "dense": {
      "block_type": "composite",
      "attention": {
        "block_type": "attention",
        "attention_type": "GQA",
        "num_query_heads": 8,
        "num_kv_heads": 2,
        "head_dim": 32
      },
      "ffn": {
        "block_type": "ffn",
        "ffn_type": "dense",
        "intermediate_size": 512,
        "gated": true
      }
    }
  }
}
