  "input_memory": "tiny-nvm",
  "nodes": [
    {
      "name": "node-0",
      "node_memory": "tiny-node-mem",
      "compute_devices": [
        { "device": "tiny-gpu", "count": 2 }
      ]
    },
    {
      "name": "node-1",
      "node_memory": "tiny-node-mem",
      "compute_devices": [
        { "device": "tiny-gpu", "count": 2 }
      ]
    }
  ]
}
