{
  "run_id": null,
  "system": "../Systems/dual-node-b200.json",
  "models_dir": "../Models",
  "tokenizer": "tiktoken",
  "output_root": "Outputs",

  "dataset": {
    "dataset": "sammshen/lmcache-agentic-traces",
    "config": "default",
    "split": "train",
    "cache_dir": "../Dataset"
  },

  "suite": {
    "name": "Example short randomized suite",
    "description": "Draws a handful of random multi-turn workloads from the cached source dataset and assigns each a model at random, for a quick end-to-end run.",
    "type": "randomized",
    "num_workloads": 4,
    "models": ["deepseek-v3.2", "gemma-4-31b", "nemotron-3-ultra"]
  },

  "max_batch_size": 8,
  "max_concurrency": 4,
  "concurrency_window_sec": 0.5,

  "allow_pdd": true,
  "prefill_engine_fraction": 0.5,

  "model_weight_loading": true,

  "auto_parallelism": false,
  "pipeline_parallel": 1,
  "expert_parallel": 1,
  "tensor_parallel": 1,
  "max_parallelism": 32,

  "prefill_chunk_size": null,
  "event_random_factor_range": 0.05,
  "arrival_interval_sec": 0.25,
  "max_turns_per_workload": 4,

  "report_time_buckets": 64,
  "random_seed": 7
}
