{
  "run_id": null,
  "system": "../Systems/heterogeneous-b200-cerebras.json",
  "models_dir": "../Models",
  "tokenizer": "tiktoken",
  "output_root": "Outputs",

  "dataset": {
    "dataset": "sammshen/lmcache-agentic-traces",
    "config": "default",
    "split": "train",
    "cache_dir": "../Dataset"
  },

  "suite": {
    "name": "Example short randomized suite",
    "description": "Draws a handful of random multi-turn workloads from the cached source dataset and assigns each a model at random, for a quick end-to-end run.",
    "type": "randomized",
    "num_workloads": 10,
    "models": ["gemma-4-31b","qwen3.6-27b"]
  },

  "max_batch_size": 1,
  "max_concurrency": null,
  "concurrency_window_sec": 0.5,

  "allow_pdd": false,
  "prefill_engine_fraction": 0.5,

  "model_weight_loading": true,

  "memory_policy": "global_lru",
  "hbm_kv_fraction": 0.5,

  "auto_parallelism": true,
  "parallelism": [
    {
      "compute_device": "nvidia-b200",
      "pipeline_parallel": 4,
      "expert_parallel": 1,
      "tensor_parallel": 4,
      "auto_parallelism": true,
      "max_parallelism": 24
    },
    {
      "compute_device": "cerebras-wse3",
      "pipeline_parallel": 2,
      "expert_parallel": 1,
      "tensor_parallel": 4,
      "auto_parallelism": true,
      "max_parallelism": 8
    }
  ],

  "prefill_chunk_size": null,
  "event_random_factor_range": 0.05,
  "arrival_interval_sec": 0.01,
  "arrival_variance_sec2": 0.0001,
  "max_turns_per_workload": 2,

  "report_time_buckets": 256,
  "random_seed": 7
}
